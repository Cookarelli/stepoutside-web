rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isValidUsername(username) {
      return username is string
        && username.size() >= 3
        && username.size() <= 20
        && username.matches('^[a-z0-9_.]+$')
        && !(username in ['admin', 'support', 'stepoutside', 'premium', 'null', 'undefined']);
    }

    function profileUsernameIsOwned(uid) {
      return !('username' in request.resource.data)
        || (
          isValidUsername(request.resource.data.username)
          && existsAfter(/databases/$(database)/documents/usernames/$(request.resource.data.username))
          && getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.username)).data.uid == uid
        );
    }

    function authEmailMatches(emailLower) {
      return emailLower == ''
        || (
          request.auth.token.email is string
          && request.auth.token.email == emailLower
        );
    }

    function discoveryUsernameIsOwned(uid) {
      return existsAfter(/databases/$(database)/documents/usernames/$(request.resource.data.username))
        && getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.username)).data.uid == uid;
    }

    function isValidFriendRequestStatus(status) {
      return status in ['pending', 'accepted', 'declined'];
    }

    function isValidDiscoveryProfile(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'usernameLower',
          'emailLower',
          'displayName',
          'photoURL',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && isValidUsername(request.resource.data.username)
        && request.resource.data.usernameLower == request.resource.data.username
        && discoveryUsernameIsOwned(uid)
        && request.resource.data.emailLower is string
        && authEmailMatches(request.resource.data.emailLower)
        && request.resource.data.displayName is string
        && request.resource.data.photoURL is string
        && request.resource.data.createdAt is number
        && request.resource.data.updatedAt is number;
    }

    function isFriendRequestParticipant(data) {
      return request.auth != null
        && (data.senderUid == request.auth.uid || data.recipientUid == request.auth.uid);
    }

    function hasExistingFriendship(senderUid, recipientUid) {
      return exists(/databases/$(database)/documents/friendships/$(senderUid + "_" + recipientUid))
        || exists(/databases/$(database)/documents/friendships/$(recipientUid + "_" + senderUid));
    }

    function hasFriendshipAfter(senderUid, recipientUid) {
      return existsAfter(/databases/$(database)/documents/friendships/$(senderUid + "_" + recipientUid))
        || existsAfter(/databases/$(database)/documents/friendships/$(recipientUid + "_" + senderUid));
    }

    function hasReversePendingFriendRequest(senderUid, recipientUid) {
      return exists(/databases/$(database)/documents/friendRequests/$(recipientUid + "_" + senderUid))
        && get(/databases/$(database)/documents/friendRequests/$(recipientUid + "_" + senderUid)).data.status == 'pending';
    }

    function hasAcceptedFriendRequestAfter(senderUid, recipientUid) {
      return (
          existsAfter(/databases/$(database)/documents/friendRequests/$(senderUid + "_" + recipientUid))
          && getAfter(/databases/$(database)/documents/friendRequests/$(senderUid + "_" + recipientUid)).data.senderUid == senderUid
          && getAfter(/databases/$(database)/documents/friendRequests/$(senderUid + "_" + recipientUid)).data.recipientUid == recipientUid
          && getAfter(/databases/$(database)/documents/friendRequests/$(senderUid + "_" + recipientUid)).data.status == 'accepted'
        )
        || (
          existsAfter(/databases/$(database)/documents/friendRequests/$(recipientUid + "_" + senderUid))
          && getAfter(/databases/$(database)/documents/friendRequests/$(recipientUid + "_" + senderUid)).data.senderUid == recipientUid
          && getAfter(/databases/$(database)/documents/friendRequests/$(recipientUid + "_" + senderUid)).data.recipientUid == senderUid
          && getAfter(/databases/$(database)/documents/friendRequests/$(recipientUid + "_" + senderUid)).data.status == 'accepted'
        );
    }

    function isValidFriendRequestCreate(requestId) {
      return request.resource.data.keys().hasOnly(['id', 'senderUid', 'recipientUid', 'status', 'createdAt'])
        && request.resource.data.id == requestId
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.recipientUid is string
        && request.resource.data.recipientUid != request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is number
        && !hasExistingFriendship(request.resource.data.senderUid, request.resource.data.recipientUid)
        && !hasReversePendingFriendRequest(request.resource.data.senderUid, request.resource.data.recipientUid);
    }

    function isValidFriendRequestResponse() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
        && resource.data.status == 'pending'
        && resource.data.recipientUid == request.auth.uid
        && request.resource.data.status in ['accepted', 'declined']
        && (
          request.resource.data.status == 'declined'
          || hasFriendshipAfter(resource.data.senderUid, resource.data.recipientUid)
        );
    }

    function isValidFriendRequestResend(requestId) {
      return request.resource.data.keys().hasOnly(['id', 'senderUid', 'recipientUid', 'status', 'createdAt'])
        && request.resource.data.id == requestId
        && resource.data.id == requestId
        && resource.data.senderUid == request.auth.uid
        && request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.recipientUid == resource.data.recipientUid
        && resource.data.status in ['accepted', 'declined']
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is number
        && !hasExistingFriendship(request.resource.data.senderUid, request.resource.data.recipientUid)
        && !hasReversePendingFriendRequest(request.resource.data.senderUid, request.resource.data.recipientUid);
    }

    function isValidFriendship(data, friendshipId) {
      return data.keys().hasOnly(['id', 'users', 'createdAt'])
        && data.id == friendshipId
        && data.users is list
        && data.users.size() == 2
        && data.users[0] is string
        && data.users[1] is string
        && data.users[0] != data.users[1]
        && data.createdAt is number;
    }

    function isFriendshipParticipant(data) {
      return request.auth != null
        && data.users is list
        && request.auth.uid in data.users;
    }

    function sessionOwnerMatchesPath(uid) {
      return (!('ownerUid' in request.resource.data) || request.resource.data.ownerUid == uid)
        && (!('userId' in request.resource.data) || request.resource.data.userId == uid);
    }

    function isLeaderboardNumber(value) {
      return value is number && value >= 0;
    }

    function canReadFriendActivity(uid) {
      return isOwner(uid)
        || (request.auth != null && hasExistingFriendship(request.auth.uid, uid));
    }

    function isValidFriendActivity(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'displayName',
          'photoURL',
          'walkCount',
          'totalDistanceM',
          'currentStreak',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.username is string
        && request.resource.data.displayName is string
        && request.resource.data.photoURL is string
        && request.resource.data.walkCount is number
        && request.resource.data.walkCount >= 0
        && request.resource.data.totalDistanceM is number
        && request.resource.data.totalDistanceM >= 0
        && request.resource.data.currentStreak is number
        && request.resource.data.currentStreak >= 0
        && request.resource.data.updatedAt is number;
    }

    function isValidLeaderboardEntry(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'displayName',
          'username',
          'photoURL',
          'weeklyMinutes',
          'weeklySessions',
          'weeklyDistanceM',
          'monthlyMinutes',
          'monthlySessions',
          'monthlyDistanceM',
          'allTimeMinutes',
          'allTimeSessions',
          'allTimeDistanceM',
          'currentStreak',
          'weekKey',
          'monthKey',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.displayName is string
        && request.resource.data.username is string
        && request.resource.data.photoURL is string
        && isLeaderboardNumber(request.resource.data.weeklyMinutes)
        && isLeaderboardNumber(request.resource.data.weeklySessions)
        && isLeaderboardNumber(request.resource.data.weeklyDistanceM)
        && isLeaderboardNumber(request.resource.data.monthlyMinutes)
        && isLeaderboardNumber(request.resource.data.monthlySessions)
        && isLeaderboardNumber(request.resource.data.monthlyDistanceM)
        && isLeaderboardNumber(request.resource.data.allTimeMinutes)
        && isLeaderboardNumber(request.resource.data.allTimeSessions)
        && isLeaderboardNumber(request.resource.data.allTimeDistanceM)
        && isLeaderboardNumber(request.resource.data.currentStreak)
        && request.resource.data.weekKey is string
        && request.resource.data.monthKey is string
        && request.resource.data.updatedAt is number;
    }

    match /routes/{routeId} {
      allow read: if true;
      allow write: if false;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && isValidUsername(username)
        && request.resource.data.keys().hasOnly(['uid', 'username', 'createdAt', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == username
        && request.resource.data.createdAt is number
        && request.resource.data.updatedAt is number;
      allow update: if request.auth != null
        && isValidUsername(username)
        && resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'username', 'createdAt', 'updatedAt'])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.username == username
        && request.resource.data.createdAt is number
        && request.resource.data.updatedAt is number;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /userDiscovery/{uid} {
      allow read: if request.auth != null;
      allow create, update: if isOwner(uid) && isValidDiscoveryProfile(uid);
      allow delete: if isOwner(uid);
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && profileUsernameIsOwned(uid);
      allow delete: if isOwner(uid);

      match /sessions/{sessionId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) && sessionOwnerMatchesPath(uid);
      }

      match /reflections/{reflectionId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /friendRequests/{requestId} {
      allow read: if isFriendRequestParticipant(resource.data);
      allow create: if request.auth != null && isValidFriendRequestCreate(requestId);
      allow update: if request.auth != null
        && (
          (isFriendRequestParticipant(resource.data) && isValidFriendRequestResponse())
          || isValidFriendRequestResend(requestId)
        );
      allow delete: if false;
    }

    match /friendships/{friendshipId} {
      allow read: if isFriendshipParticipant(resource.data);
      allow create: if request.auth != null
        && isValidFriendship(request.resource.data, friendshipId)
        && request.auth.uid in request.resource.data.users
        && hasAcceptedFriendRequestAfter(request.resource.data.users[0], request.resource.data.users[1]);
      allow update: if false;
      allow delete: if isFriendshipParticipant(resource.data);
    }

    match /friendActivity/{uid} {
      allow read: if canReadFriendActivity(uid);
      allow create, update: if isOwner(uid) && isValidFriendActivity(uid);
      allow delete: if isOwner(uid);
    }

    match /leaderboardEntries/{uid} {
      allow read: if request.auth != null;
      allow create, update: if isOwner(uid) && isValidLeaderboardEntry(uid);
      allow delete: if isOwner(uid);
    }
  }
}
