rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidUsername(username) {
      return username is string &&
        username.matches('^[a-z0-9_.]{3,20}$') &&
        !(username in ['admin', 'support', 'stepoutside', 'premium', 'null', 'undefined']);
    }

    function profileUsernameIsOwned(uid) {
      return !request.resource.data.keys().hasAny(['username']) ||
        request.resource.data.username == '' ||
        (
          isValidUsername(request.resource.data.username) &&
          getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.username)).data.uid == uid
        );
    }

    function profileUidIsValid(uid) {
      return !request.resource.data.keys().hasAny(['uid']) ||
        request.resource.data.uid == uid;
    }

    function profileUsernameLowerIsValid() {
      return !request.resource.data.keys().hasAny(['usernameLower']) ||
        !request.resource.data.keys().hasAny(['username']) ||
        request.resource.data.usernameLower == request.resource.data.username;
    }

    function isValidUserProfileWrite(uid) {
      return isOwner(uid) &&
        profileUidIsValid(uid) &&
        profileUsernameLowerIsValid() &&
        profileUsernameIsOwned(uid);
    }

    function isValidUsernameReservation(username) {
      return isSignedIn() &&
        isValidUsername(username) &&
        request.resource.data.keys().hasOnly(['uid', 'username', 'createdAt']) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.username == username &&
        request.resource.data.createdAt is timestamp;
    }

    function isCompanyAdmin(companyId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/companies/$(companyId)).data.adminUids;
    }

    function sessionOwnerMatchesPath(uid) {
      return (!('ownerUid' in request.resource.data) || request.resource.data.ownerUid == uid)
        && (!('userId' in request.resource.data) || request.resource.data.userId == uid);
    }

    match /routes/{routeId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isValidUserProfileWrite(uid);
      allow delete: if isOwner(uid);

      match /sessions/{sessionId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) && sessionOwnerMatchesPath(uid);
      }

      match /reflections/{reflectionId} {
        allow read, write: if isOwner(uid);
      }

      match /challengeProgress/{challengeId} {
        allow read, write: if isOwner(uid);
      }

      match /badges/{badgeId} {
        allow read, write: if isOwner(uid);
      }

      match /memberships/{membershipId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isValidUsernameReservation(username);
      allow update: if isValidUsernameReservation(username) &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.adminUids;
      allow update: if isCompanyAdmin(companyId);
      allow delete: if false;

      match /teams/{teamId} {
        allow read: if isSignedIn();
        allow create, update: if isCompanyAdmin(companyId);
        allow delete: if false;
      }

      match /inviteCodes/{inviteCodeId} {
        allow read: if isSignedIn();
        allow create, update: if isCompanyAdmin(companyId);
        allow delete: if false;
      }

      match /members/{memberUid} {
        allow read: if isSignedIn();
        allow create, update: if isOwner(memberUid) || isCompanyAdmin(companyId);
        allow delete: if false;
      }

      match /challengeInstances/{instanceId} {
        allow read: if isSignedIn();
        allow create, update: if isCompanyAdmin(companyId);
        allow delete: if false;
      }

      match /challengeProgress/{progressId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && request.resource.data.uid == request.auth.uid;
        allow delete: if false;
      }
    }
  }
}
